# ===== API =====
API_KEY=change_me_archie_api_key
EMBEDDING_MODEL=bge-m3
EMBEDDING_PROVIDER=ollama
EMBEDDING_VERSION=v1
QDRANT_COLLECTION=archie_knowledge_bge_m3_v1
TOP_K_DEFAULT=8
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# ===== Service URLs (inside docker network) =====
POSTGRES_URL=postgresql://archie:archie_password@postgres:5432/archie_brain
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=change_me_archie_qdrant_key
OLLAMA_URL=http://ollama:11434

# ===== Postgres =====
POSTGRES_DB=archie_brain
POSTGRES_USER=archie
POSTGRES_PASSWORD=archie_password
